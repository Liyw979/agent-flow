{
  "name": "agentflow",
  "version": "0.1.0",
  "private": true,
  "description": "Project / Task oriented OpenCode Code Agent orchestration tool",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:web": "vite build",
    "build:embedded-assets": "node scripts/generate-embedded-assets.mjs",
    "test": "tsx --test",
    "preview": "vite preview",
    "cli": "node electron/cli/launcher.cjs",
    "dist:win": "npm run build && npm run build:embedded-assets && bun build --compile --target bun-windows-x64 ./electron/cli/index.ts --outfile ./dist/agentflow.exe",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@langchain/langgraph": "^1.2.9",
    "@opencode-ai/sdk": "^0.4.0",
    "@radix-ui/react-dialog": "^1.1.6",
    "@tanstack/react-query": "^5.66.8",
    "@xyflow/react": "^12.4.4",
    "boxen": "^8.0.1",
    "clsx": "^2.1.1",
    "commander": "^14.0.3",
    "electron-updater": "^6.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^5.4.21"
  }
}
